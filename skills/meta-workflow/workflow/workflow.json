{
  "initial_stage": "planning",
  "terminal_stages": ["complete", "escalated", "cancelled"],
  "max_epoch": 20,
  "modifies_worktree": true,
  "run_files": {
    "baseline": {
      "description": "Git SHA at workflow start (used by the reviewer to diff changes)",
      "init": "git rev-parse HEAD 2>/dev/null || echo EMPTY"
    }
  },
  "stages": {
    "planning": {
      "interruptible": true,
      "execution": { "type": "inline" },
      "transitions": {
        "approved": "executing"
      },
      "inputs": {
        "required": [],
        "optional": []
      }
    },
    "executing": {
      "interruptible": false,
      "execution": {
        "type": "subagent",
        "model": "opus"
      },
      "transitions": {
        "done": "verifying"
      },
      "inputs": {
        "required": [
          { "from_stage": "planning", "description": "Implementation plan" }
        ],
        "optional": [
          { "from_stage": "reviewing", "description": "Reviewer feedback from the previous iteration" },
          { "from_stage": "qa-ing",    "description": "QA feedback from the previous iteration" },
          { "from_stage": "verifying", "description": "Quick-test failures from the previous iteration" }
        ]
      }
    },
    "verifying": {
      "interruptible": false,
      "execution": { "type": "inline" },
      "transitions": {
        "PASS": "reviewing",
        "FAIL": "executing",
        "SKIPPED": "reviewing"
      },
      "inputs": {
        "required": [],
        "optional": []
      }
    },
    "reviewing": {
      "interruptible": false,
      "execution": {
        "type": "subagent"
      },
      "transitions": {
        "PASS": "qa-ing",
        "FAIL": "executing"
      },
      "inputs": {
        "required": [
          { "from_stage": "planning",    "description": "Plan to review against" },
          { "from_stage": "executing",   "description": "Execution report" },
          { "from_stage": "verifying",   "description": "Verify report" },
          { "from_run_file": "baseline", "description": "Git SHA at workflow start — for diffing changes" }
        ],
        "optional": [
          { "from_stage": "qa-ing", "description": "QA report from the previous iteration" }
        ]
      }
    },
    "qa-ing": {
      "interruptible": false,
      "execution": {
        "type": "subagent"
      },
      "transitions": {
        "PASS": "complete",
        "FAIL": "executing"
      },
      "inputs": {
        "required": [
          { "from_stage": "planning", "description": "Plan with journey test spec" }
        ],
        "optional": []
      }
    }
  }
}
